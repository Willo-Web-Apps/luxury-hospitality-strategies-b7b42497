---
import Base from '../layouts/Base.astro';
---
<Base
  title="Velato — Boutique Hotel Consulting | Luxury & Wellness Hotel Strategy"
  description="Velato helps independent luxury and wellness hotel owners in Arizona, Costa Rica, and Europe grow revenue, improve operations, and reclaim their margins — without losing what makes them special."
>

  <!-- ═══════════════════════════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════════════════════════ -->
  <section class="relative min-h-[88vh] flex items-center overflow-hidden">
    <!-- Layered gradient background: sandstone + sage atmosphere -->
    <div class="absolute inset-0" style="background:
      radial-gradient(ellipse at 15% 60%, oklch(0.42 0.10 155 / 0.12), transparent 55%),
      radial-gradient(ellipse at 85% 20%, oklch(0.65 0.14 68 / 0.10), transparent 50%),
      radial-gradient(ellipse at 60% 90%, oklch(0.42 0.10 155 / 0.07), transparent 45%),
      linear-gradient(160deg, oklch(0.975 0.012 80) 0%, oklch(0.95 0.015 80) 60%, oklch(0.90 0.018 80) 100%);
    "></div>

    <!-- Subtle texture overlay -->
    <div class="absolute inset-0 opacity-[0.025]" style="background-image: url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%232C5545\' fill-opacity=\'1\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-32">
      <div class="max-w-3xl">
        <!-- Eyebrow -->
        <div class="inline-flex items-center gap-2 mb-8 animate-fade-in">
          <span class="h-px w-8 bg-accent-500"></span>
          <span class="text-sm font-medium tracking-widest uppercase text-accent-500 font-body">Boutique Hotel Consulting</span>
        </div>

        <!-- Headline -->
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight text-surface-900 font-display leading-[1.05] animate-slide-up">
          Your Boutique Hotel<br/>
          <em class="not-italic" style="color: oklch(0.42 0.10 155);">Deserves</em> to Be<br/>
          Truly Profitable
        </h1>

        <!-- Sub -->
        <p class="mt-7 text-lg md:text-xl text-surface-800/70 max-w-xl leading-relaxed font-body font-light animate-slide-up delay-100">
          Velato helps independent luxury and wellness hotel owners in Arizona, Costa Rica, and Europe grow revenue, improve operations, and reclaim their margins — without losing what makes them special.
        </p>

        <!-- CTAs -->
        <div class="mt-10 flex flex-col sm:flex-row items-start sm:items-center gap-4 animate-slide-up delay-200">
          <a
            href="#contact"
            class="inline-block px-8 py-4 font-semibold text-white rounded-lg transition-colors duration-150 text-base font-body"
            style="background-color: oklch(0.42 0.10 155);"
            onmouseover="this.style.backgroundColor='oklch(0.35 0.09 155)'"
            onmouseout="this.style.backgroundColor='oklch(0.42 0.10 155)'"
          >
            Book a strategy call
          </a>
          <a
            href="#how-it-works"
            class="inline-flex items-center gap-2 text-base font-medium text-surface-900/70 hover:text-surface-900 transition-colors duration-150 font-body"
          >
            See how it works
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
            </svg>
          </a>
        </div>

        <!-- Micro-proof -->
        <p class="mt-5 text-sm text-surface-800/50 font-body animate-slide-up delay-300">
          No retainer lock-ins &bull; 100% independent — always on the owner's side &bull; Arizona · Costa Rica · Europe
        </p>
      </div>
    </div>

    <!-- Decorative side element -->
    <div class="absolute right-0 top-1/2 -translate-y-1/2 hidden xl:block w-72 h-72 rounded-full opacity-10 -mr-20" style="background: radial-gradient(circle, oklch(0.42 0.10 155), transparent 70%);"></div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════
       SOCIAL PROOF BAR
  ═══════════════════════════════════════════════════════════════ -->
  <section class="py-12 border-y border-surface-200" style="background-color: oklch(0.42 0.10 155);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div>
          <p class="text-3xl md:text-4xl font-bold font-display text-white">18%</p>
          <p class="mt-1 text-sm font-body text-white/70 font-light">Average RevPAR lift<br/>in year one</p>
        </div>
        <div>
          <p class="text-3xl md:text-4xl font-bold font-display text-white">3</p>
          <p class="mt-1 text-sm font-body text-white/70 font-light">Markets: Arizona,<br/>Costa Rica &amp; Europe</p>
        </div>
        <div>
          <p class="text-3xl md:text-4xl font-bold font-display text-white">60+</p>
          <p class="mt-1 text-sm font-body text-white/70 font-light">Boutique properties<br/>advised</p>
        </div>
        <div>
          <p class="text-3xl md:text-4xl font-bold font-display text-white">100%</p>
          <p class="mt-1 text-sm font-body text-white/70 font-light">Independent — no<br/>brand affiliations</p>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════
       POSITIONING / INTRO
  ═══════════════════════════════════════════════════════════════ -->
  <section class="py-20 md:py-28 lg:py-32 bg-surface-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <!-- Left: text -->
        <div class="animate-slide-up">
          <span class="inline-flex items-center gap-2 mb-6">
            <span class="h-px w-8" style="background-color: oklch(0.65 0.14 68);"></span>
            <span class="text-sm font-medium tracking-widest uppercase font-body" style="color: oklch(0.65 0.14 68);">Why Velato</span>
          </span>
          <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight font-display text-surface-900 leading-tight">
            Boutique hotels are a different kind of business
          </h2>
          <p class="mt-6 text-lg text-surface-800/70 leading-relaxed font-body font-light">
            Generic management playbooks were written for branded, portfolio-driven hotels — not for owner-operated properties where the guest experience is deeply personal and the margins matter acutely.
          </p>
          <p class="mt-4 text-lg text-surface-800/70 leading-relaxed font-body font-light">
            Velato works exclusively with independent owners. We bring hands-on advisory in revenue strategy, operational efficiency, and wellness programming — the kind of candid, knowledgeable guidance a trusted advisor gives, not a consulting firm selling a methodology.
          </p>
          <div class="mt-8 flex items-center gap-3">
            <div class="flex -space-x-2">
              <!-- Placeholder avatar circles -->
              <div class="w-9 h-9 rounded-full border-2 border-white flex items-center justify-center text-xs font-bold text-white font-body" style="background-color: oklch(0.42 0.10 155);">A</div>
              <div class="w-9 h-9 rounded-full border-2 border-white flex items-center justify-center text-xs font-bold text-white font-body" style="background-color: oklch(0.50 0.12 155);">M</div>
              <div class="w-9 h-9 rounded-full border-2 border-white flex items-center justify-center text-xs font-bold text-white font-body" style="background-color: oklch(0.55 0.10 155);">P</div>
            </div>
            <p class="text-sm text-surface-800/60 font-body">Trusted by owners from Sedona to the Algarve</p>
          </div>
        </div>

        <!-- Right: callout card -->
        <div class="animate-slide-up delay-200">
          <div class="rounded-2xl p-8 md:p-10" style="background-color: oklch(0.95 0.015 80);">
            <blockquote class="text-xl md:text-2xl font-display text-surface-900 leading-snug italic font-light">
              "Velato understood our property's identity from day one. They didn't try to turn us into a chain — they helped us charge what we're actually worth."
            </blockquote>
            <div class="mt-6 flex items-center gap-3">
              <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold text-white font-body" style="background-color: oklch(0.42 0.10 155);">SC</div>
              <div>
                <p class="text-sm font-semibold text-surface-900 font-body">Sofia C.</p>
                <p class="text-sm text-surface-800/50 font-body">Owner, 24-room eco-luxury lodge · Costa Rica</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════
       FEATURES GRID
  ═══════════════════════════════════════════════════════════════ -->
  <section id="services" class="py-20 md:py-28 lg:py-32" style="background-color: oklch(0.95 0.015 80);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="max-w-2xl mb-16 animate-slide-up">
        <span class="inline-flex items-center gap-2 mb-6">
          <span class="h-px w-8" style="background-color: oklch(0.65 0.14 68);"></span>
          <span class="text-sm font-medium tracking-widest uppercase font-body" style="color: oklch(0.65 0.14 68);">What We Do</span>
        </span>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight font-display text-surface-900">
          Advisory built around your property, not a template
        </h2>
        <p class="mt-4 text-lg text-surface-800/70 leading-relaxed font-body font-light">
          Every engagement starts with an honest assessment of where your property sits — and where it could be.
        </p>
      </div>

      <!-- Cards grid -->
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">

        <!-- Card 1: Revenue -->
        <div class="rounded-2xl p-8 bg-surface-50 border border-surface-200/60 hover:border-brand-200 transition-colors duration-150 animate-slide-up delay-100 group">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-5" style="background-color: oklch(0.93 0.04 155);">
            <svg class="w-6 h-6" style="color: oklch(0.42 0.10 155);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold font-display text-surface-900">Revenue Strategy</h3>
          <p class="mt-3 text-base text-surface-800/65 leading-relaxed font-body font-light">
            Pricing architecture, channel mix, rate management, and length-of-stay optimization designed for boutique properties — so you capture the full value guests are already willing to pay.
          </p>
        </div>

        <!-- Card 2: Operations -->
        <div class="rounded-2xl p-8 bg-surface-50 border border-surface-200/60 hover:border-brand-200 transition-colors duration-150 animate-slide-up delay-200 group">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-5" style="background-color: oklch(0.93 0.04 155);">
            <svg class="w-6 h-6" style="color: oklch(0.42 0.10 155);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6h9.75M10.5 6a1.5 1.5 0 11-3 0m3 0a1.5 1.5 0 10-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-9.75 0h9.75"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold font-display text-surface-900">Operations &amp; Margin</h3>
          <p class="mt-3 text-base text-surface-800/65 leading-relaxed font-body font-light">
            We go line by line through your P&amp;L, staffing model, and supplier contracts to find the margin you're leaving on the table — then build an action plan your team can actually execute.
          </p>
        </div>

        <!-- Card 3: Wellness -->
        <div class="rounded-2xl p-8 bg-surface-50 border border-surface-200/60 hover:border-brand-200 transition-colors duration-150 animate-slide-up delay-300 group">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-5" style="background-color: oklch(0.93 0.04 155);">
            <svg class="w-6 h-6" style="color: oklch(0.42 0.10 155);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold font-display text-surface-900">Wellness Programming</h3>
          <p class="mt-3 text-base text-surface-800/65 leading-relaxed font-body font-light">
            Position your spa and wellness offerings as a genuine revenue driver, not a cost center. We structure programs that attract the right guest and command premium pricing.
          </p>
        </div>

        <!-- Card 4: Strategy -->
        <div class="rounded-2xl p-8 bg-surface-50 border border-surface-200/60 hover:border-brand-200 transition-colors duration-150 animate-slide-up delay-100 group">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-5" style="background-color: oklch(0.93 0.04 155);">
            <svg class="w-6 h-6" style="color: oklch(0.42 0.10 155);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.745 3.745 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.745 3.745 0 013.296-1.043A3.745 3.745 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.745 3.745 0 013.296 1.043 3.745 3.745 0 011.043 3.296A3.745 3.745 0 0121 12z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold font-display text-surface-900">Owner-Level Strategy</h3>
          <p class="mt-3 text-base text-surface-800/65 leading-relaxed font-body font-light">
            Thinking about a renovation, a rebrand, or acquiring a second property? We work through the numbers and trade-offs with you before you commit — not after.
          </p>
        </div>

        <!-- Card 5: Positioning -->
        <div class="rounded-2xl p-8 bg-surface-50 border border-surface-200/60 hover:border-brand-200 transition-colors duration-150 animate-slide-up delay-200 group">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-5" style="background-color: oklch(0.93 0.04 155);">
            <svg class="w-6 h-6" style="color: oklch(0.42 0.10 155);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold font-display text-surface-900">Market Positioning</h3>
          <p class="mt-3 text-base text-surface-800/65 leading-relaxed font-body font-light">
            Deep knowledge of the Sedona, Scottsdale, Costa Rica, and Western European luxury markets means you get positioning advice grounded in what guests in those destinations actually want.
          </p>
        </div>

        <!-- Card 6: Ongoing -->
        <div class="rounded-2xl p-8 bg-surface-50 border border-surface-200/60 hover:border-brand-200 transition-colors duration-150 animate-slide-up delay-300 group">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-5" style="background-color: oklch(0.93 0.04 155);">
            <svg class="w-6 h-6" style="color: oklch(0.42 0.10 155);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold font-display text-surface-900">Ongoing Advisory</h3>
          <p class="mt-3 text-base text-surface-800/65 leading-relaxed font-body font-light">
            Some owners want a one-time diagnostic; others want a trusted advisor on call. We offer flexible engagements — from a focused two-week sprint to a monthly retainer with full access.
          </p>
        </div>

      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════
       HOW IT WORKS
  ═══════════════════════════════════════════════════════════════ -->
  <section id="how-it-works" class="py-20 md:py-28 lg:py-32 bg-surface-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="max-w-2xl mb-16 animate-slide-up">
        <span class="inline-flex items-center gap-2 mb-6">
          <span class="h-px w-8" style="background-color: oklch(0.65 0.14 68);"></span>
          <span class="text-sm font-medium tracking-widest uppercase font-body" style="color: oklch(0.65 0.14 68);">How It Works</span>
        </span>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight font-display text-surface-900">
          From first call to measurable results in 90 days
        </h2>
        <p class="mt-4 text-lg text-surface-800/70 leading-relaxed font-body font-light">
          We don't start with a proposal — we start with an honest conversation about your property and what's actually holding revenue back.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8 md:gap-12">

        <!-- Step 1 -->
        <div class="relative animate-slide-up delay-100">
          <div class="flex items-start gap-5">
            <div class="flex-shrink-0 w-12 h-12 rounded-full flex items-center justify-center text-white font-bold font-display text-lg" style="background-color: oklch(0.42 0.10 155);">1</div>
            <div>
              <h3 class="text-xl font-bold font-display text-surface-900 mt-2">Property Discovery Call</h3>
              <p class="mt-3 text-base text-surface-800/65 leading-relaxed font-body font-light">
                A 60-minute working session where we learn your property's story, numbers, and challenges. No intake form, no sales deck — just a direct conversation.
              </p>
            </div>
          </div>
          <!-- Connector line — hidden on mobile -->
          <div class="hidden md:block absolute top-6 left-[calc(100%+1.5rem)] w-full h-px border-t-2 border-dashed" style="border-color: oklch(0.85 0.07 155); width: calc(100% - 3rem); left: calc(100% + 1.5rem);"></div>
        </div>

        <!-- Step 2 -->
        <div class="relative animate-slide-up delay-200">
          <div class="flex items-start gap-5">
            <div class="flex-shrink-0 w-12 h-12 rounded-full flex items-center justify-center text-white font-bold font-display text-lg" style="background-color: oklch(0.42 0.10 155);">2</div>
            <div>
              <h3 class="text-xl font-bold font-display text-surface-900 mt-2">Profit Diagnostic</h3>
              <p class="mt-3 text-base text-surface-800/65 leading-relaxed font-body font-light">
                We analyze your P&amp;L, rate history, channel performance, and guest data to identify exactly where your hotel is underperforming and by how much.
              </p>
            </div>
          </div>
        </div>

        <!-- Step 3 -->
        <div class="animate-slide-up delay-300">
          <div class="flex items-start gap-5">
            <div class="flex-shrink-0 w-12 h-12 rounded-full flex items-center justify-center text-white font-bold font-display text-lg" style="background-color: oklch(0.42 0.10 155);">3</div>
            <div>
              <h3 class="text-xl font-bold font-display text-surface-900 mt-2">Action Plan &amp; Execution</h3>
              <p class="mt-3 text-base text-surface-800/65 leading-relaxed font-body font-light">
                You receive a prioritized action plan with clear ownership and timelines. We stay on to help implement, not just advise from a distance.
              </p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════
       TESTIMONIAL BANNER
  ═══════════════════════════════════════════════════════════════ -->
  <section class="py-16 md:py-20 overflow-hidden" style="background-color: oklch(0.95 0.015 80);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-6">

        <div class="rounded-2xl p-8 bg-surface-50 border border-surface-200/60 animate-slide-up delay-100">
          <div class="flex gap-1 mb-4">
            <svg class="w-4 h-4" style="color: oklch(0.65 0.14 68);" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
