---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Velato — Boutique Hotel Consulting | Luxury & Wellness Hotel Strategy",
  description = "Velato helps independent luxury and wellness hotel owners in Arizona, Costa Rica, and Europe grow revenue, improve operations, and reclaim their margins — without losing what makes them special."
} = Astro.props;
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <title>{title}</title>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "ProfessionalService",
      "name": "Velato",
      "description": "Boutique hotel consulting for independent luxury and wellness hotel owners in Arizona, Costa Rica, and Europe.",
      "url": "https://luxury-hospitality-strategies.onrender.com",
      "areaServed": ["Arizona, US", "Costa Rica", "Western Europe"],
      "serviceType": ["Hotel Revenue Management", "Boutique Hotel Consulting", "Wellness Hotel Strategy"]
    }
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-surface-50 text-surface-900 font-body antialiased">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
